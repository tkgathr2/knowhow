DATABASE_URL=
OPENAI_API_KEY=
# API認証キー（空なら認証無効＝全公開。値を設定すると全/api/*でX-API-Keyヘッダー必須）
KB_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
# kb_chunks.embedding は vector(1536) 固定。EMBEDDING_DIM は必ず 1536 にする。
# 3072 等にすると挿入時に次元不一致で embedding=NULL 保存になり検索に乗らない（HNSW上限2000も抵触）。
# 次元を変える場合は db スキーマの vector(N) 再定義が必須。
EMBEDDING_DIM=1536
# GitHub Webhook署名検証用シークレット（空の場合は署名検証をスキップ）
GITHUB_WEBHOOK_SECRET=
