DATABASE_URL=
OPENAI_API_KEY=
# API認証キー（空なら認証無効＝全公開。値を設定すると全/api/*でX-API-Keyヘッダー必須）
KB_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
# kb_chunks.embedding は vector(1536) 固定。EMBEDDING_DIM は必ず 1536 にする。
# 3072 等にすると挿入時に次元不一致で embedding=NULL 保存になり検索に乗らない（HNSW上限2000も抵触）。
# 次元を変える場合は db スキーマの vector(N) 再定義が必須。
EMBEDDING_DIM=1536
# GitHub Webhook署名検証用シークレット（空の場合は署名検証をスキップ）
GITHUB_WEBHOOK_SECRET=

# --- Google ログイン（ブラウザ向け・6か月セッション）---
# 下記 CLIENT_ID/SECRET が両方設定されると、ダッシュボード(/ と /growth)と
# 閲覧APIが Google ログイン必須になる。未設定なら全開放のまま（挙動不変）。
# GCPで「OAuth 2.0 クライアント(ウェブアプリ)」を作成し、承認済みリダイレクトURIに
#   https://knowhow.up.railway.app/auth/callback  を登録して取得する。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# セッション署名鍵（任意・未設定なら KB_API_KEY を流用）。例: openssl rand -hex 32
SESSION_SECRET=
# 本番の公開URL（redirect_uri 用）。例: https://knowhow.up.railway.app
PUBLIC_BASE_URL=
# アクセス許可するメールドメイン（カンマ区切り・既定=takagi.bz,positive-z.co.jp）
ALLOWED_EMAIL_DOMAINS=takagi.bz,positive-z.co.jp
# 個別に許可するメール（カンマ区切り・任意）
ALLOWED_EMAILS=
# 再認証不要な期間（日・既定180=6か月）
SESSION_MAX_AGE_DAYS=180
